# Neo4j AuraDB
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USERNAME=<instance-id>
NEO4J_PASSWORD=<your-neo4j-password>
NEO4J_DATABASE=<instance-id>
AURA_INSTANCEID=<instance-id>
AURA_INSTANCENAME=farmscore

# Auth
JWT_SECRET=<min-32-char-random-string>
ADMIN_SECRET=<admin-secret-min-15-chars>
LENDER_SECRET=<lender-secret-min-15-chars>

# AI Narrative (Featherless)
FEATHERLESS_API_KEY=<your-featherless-api-key>
FEATHERLESS_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Google OAuth
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_CALLBACK_URL=https://<your-backend-url>/api/auth/google/callback

# URLs
FRONTEND_URL=https://<your-vercel-url>
PORT=3000

# Redis (optional — leave blank to use in-memory cache)
REDIS_URL=redis://:<password>@<host>:<port>

# Masumi
MASUMI_API_KEY=<your-masumi-api-key>
MASUMI_PAYMENT_URL=http://localhost:3001

# Encryption
ENCRYPTION_KEY=<64-char-hex-string>
